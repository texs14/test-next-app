  "tone_rules": {
    "description": "Rules for determining tones in Thai syllables",
    "tones": {
      "mid": {
        "symbol": "¯",
        "number": "1",
        "description": "Level tone at mid pitch",
        "pitch_pattern": "33",
        "examples": ["มา - maa¯ - маа¯ - come", "ดี - dii¯ - дии¯ - good"]
      },
      "low": {
        "symbol": "`",
        "number": "2", 
        "description": "Level tone at low pitch",
        "pitch_pattern": "21",
        "examples": ["หา - hàa - хàа - find", "ใส่ - sài - сài - put"]
      },
      "falling": {
        "symbol": "^",
        "number": "3",
        "description": "Falling tone from high to low",
        "pitch_pattern": "51",
        "examples": ["ไม่ - mâi - мâй - no", "ห้า - hâa - хâа - five"]
      },
      "high": {
        "symbol": "´",
        "number": "4",
        "description": "Level tone at high pitch", 
        "pitch_pattern": "45",
        "examples": ["ครับ - khráp - кхрáп - yes (male)", "น้อง - nóng - нóнг - younger"]
      },
      "rising": {
        "symbol": "ˇ",
        "number": "5",
        "description": "Rising tone from low to high",
        "pitch_pattern": "214",
        "examples": ["ไหม - mǎi - мǎй - question particle", "ฉัน - chǎn - чǎн - I"]
      }
    },
    "tone_markers": {
      "mai_ek": {
        "form": "◌่",
        "name": "ไม้เอก",
        "effects": {
          "high_class": "low",
          "mid_class": "low", 
          "low_class": "falling"
        }
      },
      "mai_tho": {
        "form": "◌้",
        "name": "ไม้โท",
        "effects": {
          "high_class": "falling",
          "mid_class": "falling",
          "low_class": "high"
        }
      },
      "mai_tri": {
        "form": "◌๊",
        "name": "ไม้ตรี",
        "effects": {
          "mid_class": "high"
        }
      },
      "mai_chattawa": {
        "form": "◌๋",
        "name": "ไม้จัตตวา",
        "effects": {
          "mid_class": "rising"
        }
      }
    },
    "tone_determination_rules": {
      "description": "How to determine the tone of a syllable",
      "factors": [
        "consonant_class",
        "syllable_type",
        "vowel_length", 
        "tone_marker",
        "final_consonant"
      ],
      "live_syllable_rules": {
        "high_class": {
          "no_mark": "rising",
          "mai_ek": "low",
          "mai_tho": "falling"
        },
